# =============================================
# AORANE API Server — Environment Variables
# Copy these to Railway > Variables
# =============================================

# Database (Supabase Transaction Pooler URL)
DATABASE_URL=postgresql://postgres.xxxx:[password]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=no-verify

# Auth
SESSION_SECRET=your-long-random-secret-min-32-chars

# SMS OTP (fast2sms.com)
FAST2SMS_API_KEY=your-fast2sms-key

# Optional: restrict CORS to specific domains
# ALLOWED_ORIGIN=yourdomain.com

# Payments (if using Razorpay)
# RAZORPAY_KEY_ID=rzp_live_xxx
# RAZORPAY_KEY_SECRETS=xxx

# Railway sets PORT automatically — do NOT set this manually
# PORT=8080
